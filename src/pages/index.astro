---
import type { MarkdownInstance } from "astro";
import SiteLayout from "../layouts/SiteLayout.astro";

type PostFrontmatter = {
  title: string;
  description: string;
  pubDate: string;
  category?: string;
  heroImage: string;
  heroAlt?: string;
  draft?: boolean;
};

const postModules = import.meta.glob<MarkdownInstance<PostFrontmatter>>(
  "./writings/*.md",
  { eager: true }
);

const posts = Object.values(postModules)
  .filter((post) => !post.frontmatter.draft)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).valueOf() -
      new Date(a.frontmatter.pubDate).valueOf()
  );

const featuredPosts = posts.slice(0, 3);
---

<SiteLayout
  title="Personal Blog"
  description="A quiet personal blog for writings with pictures."
>
  <section class="home-note" aria-labelledby="home-title">
    <h1 id="home-title">Writing</h1>
    <p class="page-intro">
      Essays, notes, and images gathered in one quiet place.
    </p>
  </section>

  <section aria-labelledby="latest-title">
    <h2 class="section-title" id="latest-title">Latest</h2>
    <div class="post-list">
      {
        featuredPosts.map((post) => (
          <article class="post-preview">
            <div>
              <p class="post-kicker">
                {new Date(post.frontmatter.pubDate).toLocaleDateString("en", {
                  year: "numeric",
                  month: "short",
                  day: "numeric"
                })}
              </p>
              <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
              <p class="post-description">{post.frontmatter.description}</p>
            </div>
            {
              post.frontmatter.heroImage && (
                <a class="post-image-link" href={post.url}>
                  <img
                    src={post.frontmatter.heroImage}
                    alt={post.frontmatter.heroAlt ?? ""}
                    loading="lazy"
                  />
                </a>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>
