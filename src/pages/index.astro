---
import type { MarkdownInstance } from "astro";
import SiteLayout from "../layouts/SiteLayout.astro";

type PostFrontmatter = {
  title: string;
  description: string;
  pubDate: string;
  category?: string;
  heroImage?: string;
  heroAlt?: string;
  draft?: boolean;
};

const postModules = import.meta.glob<MarkdownInstance<PostFrontmatter>>(
  "./writings/*.md",
  { eager: true }
);

const posts = Object.values(postModules)
  .filter((post) => !post.frontmatter.draft)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).valueOf() -
      new Date(a.frontmatter.pubDate).valueOf()
  );

const featuredPosts = posts.slice(0, 3);

const getFirstMarkdownImage = (post: MarkdownInstance<PostFrontmatter>) => {
  const rawContent = post.rawContent();
  const match = rawContent.match(/!\[([^\]]*)\]\(([^)\s]+)(?:\s+["'][^)]*["'])?\)/);

  if (match) {
    return {
      alt: match[1],
      src: match[2].replace(/^<|>$/g, "")
    };
  }

  const imageTag = rawContent.match(/<img\b[^>]*>/i)?.[0];

  if (!imageTag) {
    return undefined;
  }

  const src = imageTag.match(/\bsrc=["']([^"']+)["']/i)?.[1];
  const alt = imageTag.match(/\balt=["']([^"']*)["']/i)?.[1] ?? "";

  if (!src) {
    return undefined;
  }

  return {
    alt,
    src
  };
};
---

<SiteLayout
  title="Wells Tu"
  description="Aufhebung"
>
  <section class="home-note" aria-labelledby="home-title">
    <h1 id="home-title">Writing</h1>
    <p class="page-intro">
      散文、小说、正经人不写日记
    </p>
  </section>

  <section aria-labelledby="latest-title">
    <h2 class="section-title" id="latest-title">Latest</h2>
    <div class="post-list">
      {
        featuredPosts.map((post) => {
          const previewImage = getFirstMarkdownImage(post) ?? (
            post.frontmatter.heroImage
              ? {
                  src: post.frontmatter.heroImage,
                  alt: post.frontmatter.heroAlt ?? ""
                }
              : undefined
          );

          return (
            <article class="post-preview">
              <div class="post-preview-text">
                <p class="post-kicker">
                  {new Date(post.frontmatter.pubDate).toLocaleDateString("en", {
                    year: "numeric",
                    month: "short",
                    day: "numeric"
                  })}
                </p>
                <h2><a href={post.url}>{post.frontmatter.title}</a></h2>
                <p class="post-description">{post.frontmatter.description}</p>
              </div>
              {
                previewImage && (
                <a class="post-image-link" href={post.url}>
                  <img
                    src={previewImage.src}
                    alt={previewImage.alt}
                    loading="lazy"
                  />
                </a>
                )
              }
            </article>
          );
        })
      }
    </div>
  </section>
</SiteLayout>
