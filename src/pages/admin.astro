---
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Admin | Wells Tu</title>
    <style>
      :root {
        --background: #fff;
        --text: #111;
        --muted: rgba(0, 0, 0, 0.58);
        --line: rgba(0, 0, 0, 0.14);
        --panel: #f7f7f5;
        font-family: "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--background);
        color: var(--text);
        font-size: 15px;
      }

      button,
      input,
      textarea,
      select {
        font: inherit;
      }

      button {
        border: 1px solid var(--line);
        background: #fff;
        color: var(--text);
        cursor: pointer;
      }

      button:hover {
        background: var(--panel);
      }

      button.primary {
        border-color: #111;
        background: #111;
        color: #fff;
      }

      button.primary:hover {
        background: #333;
      }

      button:disabled {
        cursor: wait;
        opacity: 0.55;
      }

      .admin-shell {
        display: grid;
        grid-template-columns: 18rem minmax(0, 1fr);
        min-height: 100vh;
      }

      .admin-sidebar {
        border-right: 1px solid var(--line);
        padding: 1.5rem;
      }

      .admin-brand {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
      }

      .admin-brand h1 {
        margin: 0;
        font-size: 1rem;
        font-weight: 500;
      }

      .admin-brand a {
        color: var(--muted);
        font-size: 0.9rem;
        text-decoration: none;
      }

      .login-panel {
        max-width: 22rem;
      }

      .field {
        display: grid;
        gap: 0.4rem;
        margin-bottom: 1rem;
      }

      .field label {
        color: var(--muted);
        font-size: 0.88rem;
      }

      input,
      textarea,
      select {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 0;
        background: #fff;
        color: var(--text);
        padding: 0.65rem 0.7rem;
      }

      textarea {
        min-height: 5.5rem;
        resize: vertical;
      }

      .status {
        min-height: 1.4rem;
        margin-top: 1rem;
        color: var(--muted);
        line-height: 1.45;
      }

      .post-actions {
        display: grid;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
      }

      .post-list {
        display: grid;
        gap: 0.35rem;
      }

      .post-list button {
        width: 100%;
        padding: 0.6rem 0;
        border: 0;
        border-bottom: 1px solid var(--line);
        text-align: left;
      }

      .post-list small {
        display: block;
        margin-top: 0.2rem;
        color: var(--muted);
      }

      .editor-shell {
        padding: 1.5rem;
      }

      .editor-grid {
        display: grid;
        grid-template-columns: minmax(16rem, 24rem) minmax(0, 46rem);
        gap: clamp(1.5rem, 5vw, 4rem);
        align-items: start;
      }

      .meta-panel {
        position: sticky;
        top: 1.5rem;
      }

      .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.9rem;
      }

      .toolbar button,
      .toolbar select {
        width: auto;
        min-height: 2.2rem;
        padding: 0.45rem 0.62rem;
      }

      .image-tools {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.45rem;
        margin: -0.3rem 0 0.9rem;
      }

      .image-tools span {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .image-tools input[type="range"] {
        width: min(11rem, 100%);
        padding: 0;
      }

      .image-tools output {
        min-width: 2.8rem;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 1rem;
      }

      .button-row button {
        min-height: 2.4rem;
        padding: 0.55rem 0.75rem;
      }

      .editor {
        min-height: 58vh;
        border: 1px solid var(--line);
        padding: clamp(1rem, 3vw, 2rem);
        outline: none;
        font-family: "Noto Serif SC", "Songti SC", "STSong", "Source Han Serif SC", SimSun, "Times New Roman", serif;
        font-size: 1.06rem;
        line-height: 2;
        overflow-x: hidden;
      }

      .editor:focus {
        border-color: rgba(0, 0, 0, 0.38);
      }

      .editor p {
        margin: 0 0 1.45em;
        max-width: 100%;
      }

      .editor h2 {
        margin: 2rem 0 1rem;
        font-size: 1.1rem;
        font-weight: 500;
      }

      .editor img {
        display: block;
        box-sizing: border-box;
        width: 100%;
        max-width: 100%;
        height: auto;
        margin: 2rem 0;
        object-fit: contain;
        background: var(--panel);
        cursor: pointer;
      }

      .editor img.is-selected {
        outline: 2px solid #111;
        outline-offset: 4px;
      }

      .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }

      .hidden {
        display: none !important;
      }

      .inline-check {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--muted);
      }

      .inline-check input {
        width: auto;
      }

      @media (max-width: 860px) {
        .admin-shell,
        .editor-grid {
          display: block;
        }

        .admin-sidebar {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .meta-panel {
          position: static;
          margin-bottom: 1.5rem;
        }

        .editor-shell {
          padding: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="admin-brand">
          <h1>Wells Tu</h1>
          <a href="/">View site</a>
        </div>

        <form class="login-panel" id="login-form">
          <div class="field">
            <label for="username">Username</label>
            <input id="username" name="username" autocomplete="username" required />
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />
          </div>
          <button class="primary" type="submit">Sign in</button>
          <p class="status" id="login-status"></p>
        </form>

        <div id="post-sidebar" class="hidden">
          <div class="post-actions">
            <button class="primary" id="new-post-button" type="button">New article</button>
            <button id="refresh-posts-button" type="button">Refresh articles</button>
            <button id="sign-out-button" type="button">Sign out</button>
          </div>
          <div class="post-list" id="post-list"></div>
        </div>
      </aside>

      <main class="editor-shell">
        <section id="setup-panel">
          <h2>Admin API not configured</h2>
          <p class="status">
            Set <code>PUBLIC_ADMIN_API_URL</code> when building the site, then deploy the admin Worker.
          </p>
        </section>

        <section id="editor-panel" class="hidden">
          <div class="editor-grid">
            <div class="meta-panel">
              <div class="field">
                <label for="title">Title</label>
                <input id="title" />
              </div>
              <div class="field">
                <label for="slug">Slug</label>
                <input id="slug" />
              </div>
              <div class="field">
                <label for="description">Subtitle / archive summary</label>
                <textarea id="description"></textarea>
              </div>
              <div class="row">
                <div class="field">
                  <label for="pub-date">Date</label>
                  <input id="pub-date" type="date" />
                </div>
                <div class="field">
                  <label for="category">Category</label>
                  <input id="category" />
                </div>
              </div>
              <label class="inline-check">
                <input id="published" type="checkbox" checked />
                Published
              </label>
              <p class="status" id="editor-status"></p>
              <div class="button-row">
                <button id="save-draft-button" type="button">Save draft</button>
                <button class="primary" id="save-post-button" type="button">Publish</button>
              </div>
            </div>

            <div>
              <div class="toolbar" aria-label="Editor toolbar">
                <button data-command="bold" type="button"><strong>B</strong></button>
                <button data-command="italic" type="button"><em>I</em></button>
                <button data-block="p" type="button">Text</button>
                <button data-block="h2" type="button">Heading</button>
                <select id="font-family" aria-label="Font family">
                  <option value="">Font</option>
                  <option value="'Noto Serif SC', 'Songti SC', serif">Serif</option>
                  <option value="'PingFang SC', 'Hiragino Sans GB', sans-serif">Sans</option>
                  <option value="'Times New Roman', serif">Times</option>
                </select>
                <select id="font-size" aria-label="Font size">
                  <option value="">Size</option>
                  <option value="0.92em">Small</option>
                  <option value="1em">Normal</option>
                  <option value="1.16em">Large</option>
                  <option value="1.34em">Larger</option>
                </select>
                <button id="insert-image-button" type="button">Image</button>
                <input class="hidden" id="image-input" type="file" accept="image/*" />
              </div>
              <div class="image-tools hidden" id="image-tools" aria-label="Image tools">
                <span>Image</span>
                <input id="image-width" type="range" min="25" max="100" step="5" value="100" aria-label="Image width" />
                <output id="image-width-output" for="image-width">100%</output>
                <button data-image-size="40" type="button">Small</button>
                <button data-image-size="65" type="button">Medium</button>
                <button data-image-size="100" type="button">Full</button>
                <button data-image-align="left" type="button">Left</button>
                <button data-image-align="center" type="button">Center</button>
                <button data-image-align="right" type="button">Right</button>
              </div>
              <div class="editor" id="editor" contenteditable="true" spellcheck="true"></div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script is:inline define:vars={{ adminApiUrl }}>
      const apiBase = adminApiUrl.replace(/\/$/, "");
      const tokenKey = "wells-blog-admin-token";
      const loginForm = document.querySelector("#login-form");
      const loginStatus = document.querySelector("#login-status");
      const setupPanel = document.querySelector("#setup-panel");
      const postSidebar = document.querySelector("#post-sidebar");
      const editorPanel = document.querySelector("#editor-panel");
      const postList = document.querySelector("#post-list");
      const editorStatus = document.querySelector("#editor-status");
      const editor = document.querySelector("#editor");
      const imageInput = document.querySelector("#image-input");
      const imageTools = document.querySelector("#image-tools");
      const imageWidth = document.querySelector("#image-width");
      const imageWidthOutput = document.querySelector("#image-width-output");
      const fields = {
        title: document.querySelector("#title"),
        slug: document.querySelector("#slug"),
        description: document.querySelector("#description"),
        pubDate: document.querySelector("#pub-date"),
        category: document.querySelector("#category"),
        published: document.querySelector("#published")
      };

      let activeSha = "";
      let selectedImage = undefined;
      let savedRange = undefined;

      const setStatus = (node, message) => {
        node.textContent = message;
      };

      const slugify = (value) =>
        value
          .trim()
          .toLowerCase()
          .normalize("NFKD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/^-+|-+$/g, "");

      const getToken = () => localStorage.getItem(tokenKey) ?? "";

      const getErrorMessage = (error) => {
        if (error.name === "AbortError") {
          return "The request timed out. Check GitHub commits before trying again.";
        }

        return error.message || "Something went wrong.";
      };

      const request = async (path, options = {}) => {
        const { timeoutMs = 45000, ...fetchOptions } = options;
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), timeoutMs);

        const response = await fetch(`${apiBase}${path}`, {
          ...fetchOptions,
          signal: controller.signal,
          headers: {
            "Content-Type": "application/json",
            ...(getToken() ? { Authorization: `Bearer ${getToken()}` } : {}),
            ...(fetchOptions.headers ?? {})
          }
        }).finally(() => window.clearTimeout(timeout));

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(data.error ?? `Request failed with ${response.status}`);
        }

        return data;
      };

      const saveSelection = () => {
        const selection = window.getSelection();

        if (!selection || selection.rangeCount === 0) {
          return;
        }

        const range = selection.getRangeAt(0);

        if (editor.contains(range.commonAncestorContainer)) {
          savedRange = range.cloneRange();
        }
      };

      const getImageWidthPercent = (image) => {
        const width = Number.parseInt(image.style.width || "100", 10);

        if (!Number.isFinite(width)) {
          return 100;
        }

        return Math.min(100, Math.max(25, width));
      };

      const setSelectedImage = (image) => {
        if (selectedImage) {
          selectedImage.classList.remove("is-selected");
        }

        selectedImage = image;

        if (selectedImage) {
          constrainImage(selectedImage);
          imageWidth.value = getImageWidthPercent(selectedImage);
          imageWidthOutput.value = `${imageWidth.value}%`;
          selectedImage.classList.add("is-selected");
          imageTools.classList.remove("hidden");
        } else {
          imageTools.classList.add("hidden");
        }
      };

      const constrainImage = (image) => {
        image.style.maxWidth = "100%";
        image.style.height = "auto";
        image.style.boxSizing = "border-box";
        image.style.objectFit = "contain";

        if (!image.style.width || image.style.width === "auto") {
          image.style.width = "100%";
        }
      };

      const prepareContentHtml = () => {
        const clone = editor.cloneNode(true);

        clone.querySelectorAll("img").forEach((image) => {
          if (image.dataset.publishedSrc) {
            image.src = image.dataset.publishedSrc;
          } else if (image.src.startsWith("data:")) {
            throw new Error("Wait for image upload to finish before saving.");
          }

          constrainImage(image);
          delete image.dataset.uploading;
          delete image.dataset.publishedSrc;
          image.classList.remove("is-selected");
        });

        return clone.innerHTML.trim();
      };

      const insertNodeAtSavedRange = (node) => {
        editor.focus();
        const range = savedRange?.cloneRange() ?? document.createRange();

        if (!savedRange) {
          range.selectNodeContents(editor);
          range.collapse(false);
        }

        range.deleteContents();
        range.insertNode(node);
        range.setStartAfter(node);
        range.collapse(true);

        const selection = window.getSelection();
        selection.removeAllRanges();
        selection.addRange(range);
        savedRange = range.cloneRange();
      };

      const showEditor = () => {
        setupPanel.classList.add("hidden");
        loginForm.classList.add("hidden");
        postSidebar.classList.remove("hidden");
        editorPanel.classList.remove("hidden");
      };

      const resetEditor = () => {
        const today = new Date().toISOString().slice(0, 10);
        activeSha = "";
        fields.title.value = "";
        fields.slug.value = "";
        fields.description.value = "";
        fields.pubDate.value = today;
        fields.category.value = "散文";
        fields.published.checked = true;
        editor.innerHTML = "<p></p>";
        setSelectedImage(undefined);
        setStatus(editorStatus, "");
      };

      const loadPosts = async () => {
        const { posts } = await request("/api/posts");
        postList.innerHTML = "";

        posts.forEach((post) => {
          const button = document.createElement("button");
          button.type = "button";
          button.innerHTML = `${post.title}<small>${post.pubDate}${post.draft ? " - draft" : ""}</small>`;
          button.addEventListener("click", () => loadPost(post.slug));
          postList.append(button);
        });
      };

      const loadPost = async (slug) => {
        setStatus(editorStatus, "Loading article...");
        const { post } = await request(`/api/posts/${encodeURIComponent(slug)}`);
        activeSha = post.sha;
        fields.title.value = post.title;
        fields.slug.value = post.slug;
        fields.description.value = post.description;
        fields.pubDate.value = post.pubDate;
        fields.category.value = post.category;
        fields.published.checked = !post.draft;
        editor.innerHTML = post.contentHtml || "<p></p>";
        setSelectedImage(undefined);
        setStatus(editorStatus, "Loaded.");
      };

      const savePost = async ({ draft }) => {
        const title = fields.title.value.trim();
        const slug = fields.slug.value.trim() || slugify(title);

        if (!title || !slug) {
          setStatus(editorStatus, "Title and slug are required.");
          return;
        }

        const saveButton = document.querySelector("#save-post-button");
        const draftButton = document.querySelector("#save-draft-button");

        try {
          saveButton.disabled = true;
          draftButton.disabled = true;
          fields.published.checked = !draft;
          setStatus(editorStatus, draft ? "Saving draft to GitHub..." : "Publishing to GitHub...");
          const result = await request(`/api/posts/${encodeURIComponent(slug)}`, {
            method: "PUT",
            timeoutMs: 60000,
            body: JSON.stringify({
              sha: activeSha,
              title,
              slug,
              description: fields.description.value.trim(),
              pubDate: fields.pubDate.value,
              category: fields.category.value.trim() || "Writing",
              draft,
              contentHtml: prepareContentHtml()
            })
          });

          setStatus(
            editorStatus,
            result.commitSha
              ? `${draft ? "Draft saved" : "Saved to GitHub"} (${result.commitSha.slice(0, 7)}). ${
                  draft ? "It will stay hidden until you publish it." : "GitHub Pages will republish in about a minute."
                }`
              : draft
                ? "Draft saved. It will stay hidden until you publish it."
                : "Saved to GitHub. GitHub Pages will republish in about a minute."
          );
          activeSha = "";
          loadPosts().catch(() => {
            setStatus(editorStatus, "Saved to GitHub. Refresh the page to reload the article list.");
          });
        } catch (error) {
          setStatus(editorStatus, `${draft ? "Draft save" : "Publish"} failed: ${getErrorMessage(error)}`);
        } finally {
          saveButton.disabled = false;
          draftButton.disabled = false;
        }
      };

      const applySpanStyle = (style) => {
        editor.focus();
        const selection = window.getSelection();

        if (!selection || selection.rangeCount === 0 || selection.isCollapsed) {
          return;
        }

        const range = selection.getRangeAt(0);
        const span = document.createElement("span");
        Object.assign(span.style, style);

        try {
          range.surroundContents(span);
        } catch {
          span.append(range.extractContents());
          range.insertNode(span);
        }

        selection.removeAllRanges();
      };

      const insertImage = async (file) => {
        const reader = new FileReader();
        reader.addEventListener("load", async () => {
          const previewSrc = reader.result;
          const paragraph = document.createElement("p");
          const image = document.createElement("img");
          image.src = previewSrc;
          image.alt = "";
          image.dataset.uploading = "true";
          constrainImage(image);
          paragraph.append(image);
          insertNodeAtSavedRange(paragraph);
          setSelectedImage(image);
          setStatus(editorStatus, "Preview inserted. Uploading image...");

          try {
            const { src } = await request("/api/upload", {
              method: "POST",
              timeoutMs: 90000,
              body: JSON.stringify({
                filename: file.name,
                dataUrl: reader.result
              })
            });

            image.dataset.publishedSrc = src;
            delete image.dataset.uploading;
            setStatus(editorStatus, "Image inserted. Use the image controls to size or align it.");
          } catch (error) {
            image.dataset.uploading = "failed";
            setStatus(editorStatus, `Image upload failed: ${getErrorMessage(error)}`);
          }
        });
        reader.readAsDataURL(file);
      };

      const applyImageSize = (widthValue) => {
        if (!selectedImage) {
          return;
        }

        const width = Math.min(100, Math.max(25, Number(widthValue) || 100));
        selectedImage.style.width = `${width}%`;
        constrainImage(selectedImage);
        imageWidth.value = width;
        imageWidthOutput.value = `${width}%`;
      };

      const applyImageAlign = (alignment) => {
        if (!selectedImage) {
          return;
        }

        selectedImage.style.display = "block";

        if (alignment === "left") {
          selectedImage.style.margin = "1.5rem auto 1.5rem 0";
        } else if (alignment === "right") {
          selectedImage.style.margin = "1.5rem 0 1.5rem auto";
        } else {
          selectedImage.style.margin = "1.5rem auto";
        }
      };

      document.querySelectorAll("[data-command]").forEach((button) => {
        button.addEventListener("click", () => {
          document.execCommand(button.dataset.command, false);
          editor.focus();
        });
      });

      document.querySelectorAll("[data-block]").forEach((button) => {
        button.addEventListener("click", () => {
          document.execCommand("formatBlock", false, button.dataset.block);
          editor.focus();
        });
      });

      document.querySelector("#font-family").addEventListener("change", (event) => {
        if (event.target.value) {
          applySpanStyle({ fontFamily: event.target.value });
          event.target.value = "";
        }
      });

      document.querySelector("#font-size").addEventListener("change", (event) => {
        if (event.target.value) {
          applySpanStyle({ fontSize: event.target.value });
          event.target.value = "";
        }
      });

      document.querySelector("#insert-image-button").addEventListener("click", () => imageInput.click());
      imageInput.addEventListener("change", () => {
        const file = imageInput.files?.[0];
        if (file) {
          insertImage(file);
        }
        imageInput.value = "";
      });

      document.querySelectorAll("[data-image-size]").forEach((button) => {
        button.addEventListener("click", () => applyImageSize(button.dataset.imageSize));
      });

      imageWidth.addEventListener("input", () => applyImageSize(imageWidth.value));

      document.querySelectorAll("[data-image-align]").forEach((button) => {
        button.addEventListener("click", () => applyImageAlign(button.dataset.imageAlign));
      });

      editor.addEventListener("keyup", saveSelection);
      editor.addEventListener("mouseup", saveSelection);
      editor.addEventListener("focus", saveSelection);
      editor.addEventListener("click", (event) => {
        if (event.target instanceof HTMLImageElement) {
          setSelectedImage(event.target);
        } else {
          setSelectedImage(undefined);
          saveSelection();
        }
      });

      document.querySelector("#new-post-button").addEventListener("click", resetEditor);
      document.querySelector("#refresh-posts-button").addEventListener("click", loadPosts);
      document.querySelector("#save-draft-button").addEventListener("click", () => savePost({ draft: true }));
      document.querySelector("#save-post-button").addEventListener("click", () => savePost({ draft: false }));
      document.querySelector("#sign-out-button").addEventListener("click", () => {
        localStorage.removeItem(tokenKey);
        window.location.reload();
      });

      fields.title.addEventListener("input", () => {
        if (!activeSha) {
          fields.slug.value = slugify(fields.title.value);
        }
      });

      loginForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        setStatus(loginStatus, "Signing in...");

        try {
          const formData = new FormData(loginForm);
          const { token } = await request("/api/login", {
            method: "POST",
            body: JSON.stringify({
              username: formData.get("username"),
              password: formData.get("password")
            })
          });

          localStorage.setItem(tokenKey, token);
          showEditor();
          resetEditor();
          await loadPosts();
        } catch (error) {
          setStatus(loginStatus, error.message);
        }
      });

      if (!apiBase) {
        loginForm.classList.add("hidden");
      } else if (getToken()) {
        showEditor();
        resetEditor();
        loadPosts().catch(() => {
          localStorage.removeItem(tokenKey);
          window.location.reload();
        });
      } else {
        setupPanel.classList.add("hidden");
      }
    </script>
  </body>
</html>
