---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="About" description="About the author and the blog.">
  <header class="page-head">
    <h1 class="page-title">About</h1>
  </header>

  <section class="about-grid">
    <div class="prose">
      <p>
        This is a quiet place for essays, images, observations, and drafts that need
        more space than a social feed.
      </p>
      <p>
        Edit this page in <code>src/pages/about.astro</code>. Replace the name, the
        short bio, and the picture with your own details before publishing.
      </p>
      <p>
        For contact, add an email address or links to places where readers can find you.
      </p>
    </div>
    <img class="about-image" src="/images/studio-window.jpg" alt="Light falling across a quiet desk" />
  </section>
</SiteLayout>
