---
import SiteLayout from "./SiteLayout.astro";

const { frontmatter } = Astro.props;

const title = frontmatter.title ?? "Untitled";
const description = frontmatter.description ?? "";
const pubDate = frontmatter.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString("en", {
      year: "numeric",
      month: "long",
      day: "numeric"
    })
  : "";
---

<SiteLayout title={title} description={description}>
  <article>
    <header class="post-hero">
      <div>
        <p class="post-kicker">{pubDate}</p>
        <h1>{title}</h1>
        {description && <p class="page-intro">{description}</p>}
      </div>
      {
        frontmatter.heroImage && (
          <img
            class="post-hero-image"
            src={frontmatter.heroImage}
            alt={frontmatter.heroAlt ?? ""}
          />
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/archive/">Back to archive</a>
    </footer>
  </article>
</SiteLayout>
